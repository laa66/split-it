# Copy to .env and fill in. .env is gitignored.

# --- HTTP ---
HTTP_PORT=80

# --- Database ---
POSTGRES_DB=splitit
POSTGRES_USER=splitit
POSTGRES_PASSWORD=change-me

# --- Backend ---
SPRING_PROFILES_ACTIVE=prod
APP_BASE_URL=http://localhost

# JWT — must be at least 32 bytes. Generate: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRATION_HOURS=24
INVITATION_EXPIRATION_DAYS=7

# Reminder scheduler cron (Spring format: sec min hour day month weekday).
# Default: Mondays at 09:00.
REMINDER_CRON=0 0 9 * * MON

# --- Email (PROD: Gmail SMTP with app password) ---
# In dev these are overridden to Mailhog automatically.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@gmail.com
MAIL_PASS=app-password-generated-in-google
